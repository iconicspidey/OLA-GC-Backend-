{
  "name": "epin.com.ng",
  "version": "1.0.0",
  "description": "Sequelize-express-sequelize-mysql boilerplate",
  "main": "index.js",
  "scripts": {
    "test": "npx eslint src/",
    "dev": "npx nodemon index.js",
    "start": "node index.js",
    "db:setup": "npx sequelize db:migrate --migrations-path=src/database/migrations",
    "db:empty": "npx sequelize db:migrate:undo:all --migrations-path=src/database/migrations"
  },
  "keywords": [
    "boilerplate"
  ],
  "author": "tasiukwaplong",
  "license": "ISC",
  "dependencies": {
    "axios": "^0.21.0",
    "body-parser": "^1.19.0",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "morgan": "^1.10.0",
    "mysql2": "^2.1.0",
    "password-hash": "^1.2.2",
    "sequelize": "^5.22.3"
  },
  "devDependencies": {
    "eslint": "^6.8.0",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-plugin-import": "^2.20.1",
    "nodemon": "^2.0.4"
  }
}
